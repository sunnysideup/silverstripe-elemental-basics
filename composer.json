{
    "name": "sunnysideup/elemental-basics",
    "description": "Provides a Base Element Extension to Elemental that allows the content editor to make basic design / styling choices such as top and bottom margin and background colour",
    "type": "silverstripe-vendormodule",
    "keywords": [
        "styling",
        "design",
        "elemental",
        "extension",
        "margin",
        "padding",
        "background-colour",
        "blocks"
    ],
    "license": "BSD-3-Clause",
    "require": {
        "silverstripe/framework": "^6.0",
        "silverstripe/admin": "^3.0",
        "dnadesign/silverstripe-elemental": "^6.0",
        "sunnysideup/selected-colour-picker": "dev-main"
    },
    "require-dev": {
    },
    "autoload": {
        "psr-4": {
            "Sunnysideup\\ElementalBasics\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Nicolaas Thiemen Francken",
            "email": "modules@sunnysideup.co.nz",
            "role": "lead developer"
        }
    ],
    "yet-to-update": {
        "sunnysideup/selected-colour-picker": {
            "section": "require",
            "current": "^5.0-dev",
            "reason": "no-compatible-stable-release"
        }
    }
}
